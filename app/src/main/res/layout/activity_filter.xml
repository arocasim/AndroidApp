<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="720dp">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@color/primary_light"
            android:contentDescription="Close"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/primary_dark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/titleFilters"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Article Filters"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@id/btnClose"
            app:layout_constraintBottom_toBottomOf="@id/btnClose"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnClose" />

        <TextView
            android:id="@+id/labelCategories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Categories"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/btnClose"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCategories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:singleSelection="false"
            app:selectionRequired="false"
            app:singleLine="false"
            app:chipSpacingHorizontal="10dp"
            app:chipSpacingVertical="10dp"
            app:layout_constraintTop_toBottomOf="@id/labelCategories"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCat1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Technology"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCat2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Science"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCat3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Environment"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCat4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Health"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCat5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Business"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCat6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sport"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/labelStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Reading style"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/chipGroupCategories"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:singleSelection="true"
            app:selectionRequired="false"
            app:singleLine="false"
            app:chipSpacingHorizontal="10dp"
            app:chipSpacingVertical="10dp"
            app:layout_constraintTop_toBottomOf="@id/labelStyle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSSS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Long"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/labelToggle1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Only newest articles"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/chipGroupStyle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/switchOption1" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchOption1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/labelToggle1"
            app:layout_constraintBottom_toBottomOf="@id/labelToggle1"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/labelSort"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Sort by"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/labelToggle1"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSort"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:singleSelection="true"
            app:selectionRequired="false"
            app:singleLine="false"
            app:chipSpacingHorizontal="10dp"
            app:chipSpacingVertical="10dp"
            app:layout_constraintTop_toBottomOf="@id/labelSort"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSortTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSortAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Author"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSortNewest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Newest"
                android:textColor="@color/text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/primary_light"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp" />
        </com.google.android.material.chip.ChipGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:text="Reset"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            app:cornerRadius="14dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/primary"
            app:backgroundTint="@color/primary_light"
            app:layout_constraintTop_toBottomOf="@id/chipGroupSort"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnApply"
            app:layout_constraintWidth_percent="0.48" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApply"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:text="Apply"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="14dp"
            app:backgroundTint="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/chipGroupSort"
            app:layout_constraintStart_toEndOf="@id/btnReset"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.48" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
